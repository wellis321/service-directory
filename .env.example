# Copy to ".env" for local use. On Hostinger, create the same file in the project root
# (same folder as includes/) via File Manager or SFTP — never commit .env.

# local | staging | production
APP_ENV=local
APP_DEBUG=true

DB_HOST=127.0.0.1
# MAMP: MySQL often listens on 8889 — required for CLI (php cron/import.php) if 3306 is closed
# DB_PORT=8889
# Or use MAMP’s socket (then DB_PORT is ignored):
# DB_SOCKET=/Applications/MAMP/tmp/mysql/mysql.sock
DB_NAME=service-directory
DB_USER=
DB_PASS=

# No trailing slash
SITE_URL=http://localhost:8888
SITE_NAME=CareScotland

FROM_EMAIL=
FROM_NAME=CareScotland

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_PRO=

# Update monthly: https://www.careinspectorate.com/index.php/publications-statistics/44-public/93-datastore
CI_CSV_URL=https://www.careinspectorate.com/images/Datastore/260331_DatastoreExternal.csv
